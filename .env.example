# Postgres credentials, used both to provision the postgres container and to
# build the in-network DATABASE_URL for the migrate/app containers in
# docker-compose.yml (which connect via the "postgres" service name).
POSTGRES_USER=carrental
POSTGRES_PASSWORD=changeme
POSTGRES_DB=carrental

# Used by host-side tooling only (drizzle-kit generate, local `npm run dev`
# outside Docker) — points at the port Postgres publishes to localhost.
DATABASE_URL=postgres://carrental:changeme@localhost:5432/carrental

# better-auth
# Generate with: npx @better-auth/cli secret
BETTER_AUTH_SECRET=changeme
BETTER_AUTH_URL=http://localhost:3000

# Where uploaded documents (paperwork, import source files) are stored.
UPLOAD_DIR=./uploads
